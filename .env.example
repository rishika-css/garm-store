# ─── GARM Store — WooCommerce API credentials ─────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Your Hostinger domain (no trailing slash)
REACT_APP_WC_URL=https://yourdomain.com

# WooCommerce REST API keys
# Generate at: WordPress Admin → WooCommerce → Settings → Advanced → REST API
REACT_APP_WC_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
REACT_APP_WC_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
